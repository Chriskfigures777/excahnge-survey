# Copy to .env.local (never commit .env.local).

AIRTABLE_PERSONAL_ACCESS_TOKEN=
AIRTABLE_BASE_ID=

# Optional — if setup created "Survey Responses (Relational)" next to a legacy table:
# AIRTABLE_SURVEY_RESPONSES_TABLE=Survey Responses (Relational)

AIRTABLE_SURVEY_WAVE_KEY=pilot-2026
# SURVEY_VERSION=2026.1

# Each response row gets "Respondent Name" (First Last, or email). If your table lacks that column:
# AIRTABLE_SKIP_RESPONDENT_NAME_FIELD=1

# Older bases with columns Q1–Q30 and "Open-Ended Response Fields" only:
# AIRTABLE_USE_LEGACY_Q_FIELD_NAMES=1
# (The app also auto-detects legacy vs section-named columns via Airtable Meta when this is unset.)
